{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PalworldModManager",
  "version": "0.1.0",
  "identifier": "com.htaeky.palworldmodmanager",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      { "title": "Palworld Mod Manager", "width": 1000, "height": 600, "minWidth": 860, "minHeight": 540, "resizable": true }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/libUE4SS.dylib", "resources/UE4SS-settings.ini", "resources/ue4ss-version.txt", "resources/retoc", "resources/retoc-version.txt", "resources/loader-mods"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
